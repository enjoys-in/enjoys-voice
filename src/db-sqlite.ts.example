// src/db.ts
import sqlite3 from 'sqlite3';
import { open } from 'sqlite';

let db: any;

export async function initDB() {
  db = await open({
    filename: './sip.db',
    driver: sqlite3.Database
  });

  await db.exec(`
    CREATE TABLE IF NOT EXISTS users (
      phone TEXT PRIMARY KEY,
      name TEXT,
      password TEXT
    );
    CREATE TABLE IF NOT EXISTS call_logs (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      direction TEXT,
      from_user TEXT,
      to_user TEXT,
      name TEXT,
      time TEXT,
      status TEXT DEFAULT 'completed'
    );
  `);
}

export const DB = {
  async register(phone: string, name: string, password: string) {
    await db.run('INSERT OR REPLACE INTO users (phone, name, password) VALUES (?, ?, ?)', phone, name, password);
  },
  async getName(phone: string) {
    const row = await db.get('SELECT name FROM users WHERE phone = ?', phone);
    return row?.name;
  },
  async getPassword(phone: string) {
    const row = await db.get('SELECT password FROM users WHERE phone = ?', phone);
    return row?.password;
  },
  async logCall(data: any) {
    await db.run(
      'INSERT INTO call_logs (direction, from_user, to_user, name, time, status) VALUES (?, ?, ?, ?, ?, ?)',
      data.direction, data.from, data.to || '', data.name, data.time, data.status || 'completed'
    );
  },
  async getCalls() {
    return await db.all('SELECT * FROM call_logs ORDER BY id DESC');
  },
  async getMissedCalls() {
    return await db.all("SELECT * FROM call_logs WHERE direction = 'incoming' AND status = 'missed' ORDER BY id DESC");
  }
};


// src/app.ts
import express from 'express';
import bodyParser from 'body-parser';
import path from 'path';
import { DB, initDB } from './db';
import { SipGateway } from './sipGateway';
import { CallManager } from './callManager';

const app = express();
app.use(bodyParser.json());
app.use(express.static(path.join(__dirname, '../web')));

initDB().then(() => new SipGateway());

app.post('/register', async (req, res) => {
  const { phone, name, password } = req.body;
  if (!phone || !name || !password) return res.status(400).send({ error: 'Missing fields' });
  await DB.register(phone, name, password);
  res.send({ success: true });
});

app.get('/calls', async (req, res) => {
  res.send(await DB.getCalls());
});

app.get('/missed', async (req, res) => {
  res.send(await DB.getMissedCalls());
});

app.post('/call', async (req, res) => {
  const { to, from } = req.body;
  const callerName = await DB.getName(from) || from;
  try {
    await CallManager.makeCall(to, callerName);
    await DB.logCall({
      direction: 'outgoing', from, to, name: callerName, time: new Date().toISOString(), status: 'completed'
    });
    res.send({ success: true });
  } catch (err) {
    console.error(err);
    await DB.logCall({
      direction: 'outgoing', from, to, name: callerName, time: new Date().toISOString(), status: 'failed'
    });
    res.status(500).send({ error: 'Call failed' });
  }
});

app.listen(3000, () => console.log('API running on http://localhost:3000'));


