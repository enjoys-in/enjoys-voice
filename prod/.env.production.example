# ════════════════════════════════════════════════════════════════
#  CallNet — PRODUCTION environment (VPS 77.237.241.24)
#  Copy this file to `prod/.env` and fill in the REPLACE_ME values.
#  This file does NOT affect your local/dev setup.
# ════════════════════════════════════════════════════════════════

# ─── Public identity ─────────────────────────────────────────────
# The domain that points (A record) to your VPS 77.237.241.24.
# Caddy uses this to obtain a free Let's Encrypt TLS certificate.
DOMAIN=voice.enjoys.in          # REPLACE_ME with your real domain

# Public IPv4 of the VPS. Used by FreeSWITCH/drachtio in SDP & SIP headers
# so that RTP/media flows back to the right address.
PUBLIC_IP=77.237.241.24

# ─── Public URLs returned to the browser (TLS, via Caddy) ────────
# Because the UI is served over HTTPS, these MUST be wss:// (not ws://).
# Caddy terminates TLS and proxies these paths internally.
PUBLIC_API_BASE=https://voice.enjoys.in         # REPLACE_ME domain
PUBLIC_WS_URL=wss://voice.enjoys.in/signal         # app signaling socket
PUBLIC_SIP_WS_URL=wss://voice.enjoys.in/sip        # drachtio SIP-over-WS

# ─── Secrets — CHANGE ALL OF THESE ───────────────────────────────
DRACHTIO_SECRET=REPLACE_ME_strong_random_1
FREESWITCH_SECRET=REPLACE_ME_strong_random_2

# ─── Internal service wiring (container DNS names) ───────────────
# These point at other services on the compose network — usually leave as-is.
DRACHTIO_HOST=drachtio-server
DRACHTIO_PORT=9022
FREESWITCH_HOST=drachtio-freeswitch
FREESWITCH_PORT=8021
# FreeSWITCH connects back to the API container's ESL outbound listener.
FREESWITCH_LISTEN_ADDRESS=api
FREESWITCH_LISTEN_PORT=8085

# ─── App ports (internal; exposed only through Caddy) ────────────
HTTP_PORT=3001
WS_PORT=3002
SIP_WS_PORT=5065

# ─── TURN / coturn (WebRTC media across NAT) ─────────────────────
# A long-term-credential static secret shared between coturn and clients.
TURN_REALM=voice.enjoys.in                      # REPLACE_ME domain
TURN_SECRET=REPLACE_ME_turn_shared_secret
TURN_USER=callnet                                  # static user (simple mode)
TURN_PASSWORD=REPLACE_ME_turn_password

# ICE servers injected at RUNTIME into the web container (see web-entrypoint.sh).
# STUN for reflexive candidates + your own TURN for relay fallback.
PUBLIC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:77.237.241.24:3478","username":"callnet","credential":"REPLACE_ME_turn_password"}]

# ─── IVR ─────────────────────────────────────────────────────────
IVR_ENABLED=true
IVR_ENTRY=5000
IVR_DEFAULT_LANG=en

# ─── SIP Trunk (outbound PSTN) — fill for your provider ──────────
TRUNK_NAME=telnyx
TRUNK_HOST=
TRUNK_PORT=5060
TRUNK_TRANSPORT=udp
TRUNK_USERNAME=
TRUNK_PASSWORD=
TRUNK_CALLER_NUMBER=
TRUNK_PREFIX=
