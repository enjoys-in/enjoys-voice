# ════════════════════════════════════════════════════════════════
#  CallNet — PRODUCTION environment (VPS 77.237.241.24)
#  Copy this file to `prod/.env` and fill in the REPLACE_ME values.
#  This file does NOT affect your local/dev setup.
# ════════════════════════════════════════════════════════════════

# ─── Public identity ─────────────────────────────────────────────
# The domain that points (A record) to your VPS 77.237.241.24.
# Caddy uses this to obtain a free Let's Encrypt TLS certificate.
DOMAIN=voice.enjoys.in          # REPLACE_ME with your real domain

# Public IPv4 of the VPS. Used by FreeSWITCH/drachtio in SDP & SIP headers
# so that RTP/media flows back to the right address.
PUBLIC_IP=77.237.241.24

# ─── Public URLs returned to the browser (TLS, via Caddy) ────────
# Because the UI is served over HTTPS, these MUST be wss:// (not ws://).
# Caddy terminates TLS and proxies these paths internally.
PUBLIC_API_BASE=https://voice.enjoys.in         # REPLACE_ME domain
PUBLIC_WS_URL=wss://voice.enjoys.in/signal         # app signaling socket
PUBLIC_SIP_WS_URL=wss://voice.enjoys.in/sip        # drachtio SIP-over-WS

# Origins allowed to open the signaling WebSocket (CSWSH defense). MUST include
# the public HTTPS origin or the browser handshake to /signal is REJECTED
# (only localhost is allowed when this is empty — which is why signaling fails
# in prod while SIP, which has no origin check, still works). Comma-separated.
ALLOWED_ORIGINS=https://voice.enjoys.in            # REPLACE_ME domain

# ─── Secrets — CHANGE ALL OF THESE ───────────────────────────────
DRACHTIO_SECRET=REPLACE_ME_strong_random_1
FREESWITCH_SECRET=REPLACE_ME_strong_random_2

# ─── Internal service wiring (container DNS names) ───────────────
# These point at other services on the compose network — usually leave as-is.
DRACHTIO_HOST=drachtio-server
DRACHTIO_PORT=9022
FREESWITCH_HOST=drachtio-freeswitch
FREESWITCH_PORT=8021
# FreeSWITCH connects back to the API container's ESL outbound listener.
FREESWITCH_LISTEN_ADDRESS=api
FREESWITCH_LISTEN_PORT=8085

# TTS engine/voice for IVR `say:` prompts. The custom image
# (mullayam06/freeswitch-piper) bundles Piper + mod_tts_commandline as the
# default engine, so use neural Piper TTS. To fall back to the stock
# safarov/freeswitch image, set flite / slt (mod_flite is built in; Piper is not).
TTS_ENGINE=tts_commandline
TTS_VOICE=en_US-amy-medium

# ─── App ports (internal; exposed only through Caddy) ────────────
HTTP_PORT=3001
WS_PORT=3002
SIP_WS_PORT=5065

# ─── TURN / coturn (WebRTC media across NAT) ─────────────────────
# Mode A (DEFAULT) — static long-term credential. Simple: the same
# username/password ships to every browser. Must match coturn's `user=` and the
# PUBLIC_ICE_SERVERS credential below.
# NOTE: no inline (same-line) comments on TURN_REALM — coturn folds a trailing
# "# ..." into the realm value and silently breaks credential auth.
TURN_REALM=voice.enjoys.in
TURN_USER=callnet
TURN_PASSWORD=devsecret123

# Mode B (RECOMMENDED) — ephemeral (time-limited) credentials. When set, the API
# mints a short-lived HMAC TURN credential per client instead of shipping the
# static password, so a leaked credential expires within TURN_CRED_TTL seconds.
# To enable: set this to a strong random secret, set the SAME value as coturn's
# `static-auth-secret` (uncomment use-auth-secret block in prod/coturn/turnserver.conf),
# and leave the static username/credential out of PUBLIC_ICE_SERVERS below.
# Empty (default) keeps Mode A. See prod/coturn/turnserver.conf for full steps.
TURN_STATIC_AUTH_SECRET=                           # REPLACE_ME to enable Mode B
TURN_CRED_TTL=3600                                 # minted credential lifetime (s)

# ICE servers injected at RUNTIME into the web container (see web-entrypoint.sh).
# STUN for reflexive candidates + your own TURN for relay fallback. In Mode B the
# API overrides the username/credential on turn: entries, but the Next.js dialer
# still reads these static values — keep them valid (Mode A) until the dialer is
# wired to fetch ephemeral creds.
PUBLIC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:77.237.241.24:3478","username":"callnet","credential":"devsecret123"}]

# ─── IVR ─────────────────────────────────────────────────────────
IVR_ENABLED=true
IVR_ENTRY=5000
IVR_DEFAULT_LANG=en

# ─── SIP Trunk (outbound PSTN) — fill for your provider ──────────
TRUNK_NAME=telnyx
TRUNK_HOST=
TRUNK_PORT=5060
TRUNK_TRANSPORT=udp
TRUNK_USERNAME=
TRUNK_PASSWORD=
TRUNK_CALLER_NUMBER=
TRUNK_PREFIX=
