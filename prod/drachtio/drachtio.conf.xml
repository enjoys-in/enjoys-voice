<drachtio>
  <logging>
    <console/>
    <loglevel>info</loglevel>
    <sofia-loglevel>3</sofia-loglevel>
  </logging>

  <sip>
    <contacts>
      <!-- PSTN trunk / external SIP UAs over plain UDP + TCP (public :5060). -->
      <contact>sip:*@0.0.0.0:5060;transport=udp,tcp</contact>

      <!-- Browser SIP.js over SECURE WebSocket (:5066).
           Caddy terminates the public TLS at https://DOMAIN/sip and RE-ENCRYPTS
           to this listener, so the transport drachtio actually receives is wss
           and genuinely matches the `Via: SIP/2.0/WSS` that SIP.js stamps. A
           plain-ws listener behind a TLS-terminating proxy would reject that
           Via with "400 Bad Request" (invalid transport). -->
      <contact>sips:*@0.0.0.0:5066;transport=wss</contact>
    </contacts>

    <!-- TLS for the wss listener above. Uses the SAME cert Caddy serves
         (mounted read-only from the host's /etc/caddy/certs). The only client
         is Caddy on the internal docker network (tls_insecure_skip_verify), so
         any valid cert works; reusing the real one avoids a second cert to
         manage. Host files: enjoys.in.pem (cert) + enjoys.in.key (key). -->
    <tls>
      <key-file>/etc/drachtio/tls/enjoys.in.key</key-file>
      <cert-file>/etc/drachtio/tls/enjoys.in.pem</cert-file>
    </tls>

    <!-- Drop known SIP scanners outright (toll-fraud / war-dialers). -->
    <spammers action="reject" tcp-action="discard">
      <header name="User-Agent">
        <value>sip-cli</value>
        <value>sipcli</value>
        <value>friendly-scanner</value>
        <value>pplsip</value>
        <value>sipvicious</value>
      </header>
      <header name="To">
        <value>sipvicious</value>
      </header>
    </spammers>
  </sip>

  <admin port="9022" secret="siprocks">0.0.0.0</admin>
</drachtio>
