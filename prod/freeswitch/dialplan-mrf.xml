<include>
  <!-- PROD-ONLY override of docker/freeswitch_configs/dialplan/mrf.xml.
       Mounted over /etc/freeswitch/dialplan/mrf.xml by docker-compose.prod.yml
       (a single-file bind on the longer dest path wins over the
       ./freeswitch_configs dir mount). Referenced ONLY by the prod compose,
       never by the dev compose — so local keeps its current (strict SDES)
       behaviour while prod relaxes SRTP so real WebRTC browsers can connect.

       WHY THIS DIFFERS FROM DEV: a WebRTC browser offers DTLS-SRTP
       (m=audio ... UDP/TLS/RTP/SAVPF + a=fingerprint, NO a=crypto). The dev
       file forces SDES on the inbound leg (rtp_secure_media_inbound=true), so
       FreeSWITCH requires an a=crypto suite the offer never contains and logs
       "switch_core_media.c:5606 Crypto not negotiated but required" -> media
       fails, call drops ~3.5s after answer. Local "works" only because the
       browser and FreeSWITCH share one host (no NAT), so the path is rarely
       exercised. In prod we relax both knobs to `optional`: DTLS is then
       auto-detected from the fingerprint and SDES is still accepted if a peer
       (e.g. a SIP trunk leg) actually offers a=crypto. -->
  <context name="mrf">

    <!-- drachtio-fsmrf: establish outbound event socket connection back to the
         api container. Hardcoded to its pinned voipnet IP (10.89.0.10:8085);
         the X-esl-outbound header (from FREESWITCH_LISTEN_ADDRESS) carries the
         same value, so this just removes any dependence on the header surviving
         the drachtio relay. -->
    <extension name="socket">
      <condition field="${sip_user_agent}" expression="^drachtio-fsmrf:(.*)$">
        <!-- DIAGNOSTIC: confirm this extension matched and show the exact
             ESL-outbound callback FreeSWITCH will dial back to. ERR level so it
             surfaces in `docker logs drachtio-freeswitch`. If you place a call
             and this line does NOT appear, the INVITE never reached the mrf
             context / the User-Agent did not match -> a SIP-routing problem, not
             an ESL one. If it DOES appear but connectCaller still times out, the
             failure is on the answer/media or the outbound-socket leg. -->
        <action application="log" data="ERR HIT SOCKET DIALPLAN ua=${sip_user_agent} esl=${sip_h_X-esl-outbound}"/>
        <!-- optional = negotiate SRTP only if the peer offers it; let a DTLS
             (WebRTC) offer fall through to DTLS auto-negotiation from the
             a=fingerprint instead of requiring an a=crypto suite. -->
        <action application="set" data="rtp_secure_media=optional"/>
        <action application="set" data="rtp_secure_media_inbound=optional"/>
        <action application="answer"/>
        <action application="set" data="send_silence_when_idle=-1"/>
        <action application="set" data="hangup_after_bridge=false"/>
        <action application="set" data="park_after_bridge=true"/>
        <action application="set" data="playback_terminators=none"/>
        <!-- Update this IP if the api service ipv4_address in
             docker-compose.prod.yml changes. -->
        <action application="socket" data="10.89.0.10:8085 async full"/>
      </condition>
    </extension>
  </context>
</include>
