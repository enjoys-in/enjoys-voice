# ════════════════════════════════════════════════════════════════
#  Caddy reverse proxy — automatic HTTPS (Let's Encrypt)
#  Serves voice.enjoys.in (A record → VPS 77.237.241.24).
#  Caddy runs on the HOST; the compose stack publishes its ports to
#  localhost, so upstreams are reached via 127.0.0.1:<published-port>.
# ════════════════════════════════════════════════════════════════

voice.enjoys.in {
	encode zstd gzip

	# ── SIP over WebSocket (drachtio) → wss://DOMAIN/sip ──────────	 
	@sip path /sip /sip/*
	handle @sip {
		reverse_proxy https://127.0.0.1:5065 {
			transport http {
				tls_server_name voice.enjoys.in
				versions 1.1
			}
		}
	}

	# ── App signaling WebSocket → wss://DOMAIN/signal ─────────────
	@signal path /signal /signal/*
	handle @signal {
		reverse_proxy 127.0.0.1:3002
	}

	# ── Go CRUD API → https://DOMAIN/api/g/* (auth, IVR, lookup, …) ──
	handle /api/g/* {
		reverse_proxy 127.0.0.1:3003
	}

	# ── Node engine API → https://DOMAIN/api/n/* (live telephony) ──
	handle /api/n/* {
		reverse_proxy 127.0.0.1:3001
	}

	# ── Frontend (Next.js) — everything else ─────────────────────
	# web container runs `next start -p 4500` (web/package.json start script).
	handle {
		reverse_proxy 127.0.0.1:4500
	}
}
