<drachtio>
  <logging level="info" />
  <sip-address>0.0.0.0</sip-address> 
  <sip-stack>
    <udp port="5060" />
    <tcp port="5060" />
    <wss port="5066">
      <cert>/etc/drachtio/certs/server.crt</cert>
      <key>/etc/drachtio/certs/server.key</key>
    </wss>
    <ws port="5065" />
  </sip-stack>
  <console-port>9022</console-port>
  <contact>"sip:*@127.0.0.1:5060;transport=udp"</contact>
  
  <admin>
    <address>0.0.0.0</address>
    <port>9022</port>
    <secret>siprocks</secret>
  </admin>

  <request-handlers>
    <request-handler sip-method="INVITE">
      <action>route</action>
    </request-handler>
    <request-handler sip-method="REGISTER">
      <action>route</action>
    </request-handler>
    <request-handler sip-method="OPTIONS">
      <action>route</action>
    </request-handler>
  </request-handlers>
</drachtio>
