<profile name="drachtio_mrf">
  <!--
    Dedicated media-server profile driven by drachtio-fsmrf.
    Mirrors the proven config from the drachtio/drachtio-freeswitch-mrf image.
    Bound to port 5090 (5080 is used by the vanilla `external` profile).
  -->
  <domains>
    <domain name="all" alias="true" parse="false"/>
  </domains>

  <settings>
    <param name="sip-trace" value="no"/>
    <param name="rfc2833-pt" value="101"/>
    <param name="dtmf-type" value="rfc2833"/>
    <param name="inbound-late-negotiation" value="true"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="5090"/>
    <!-- Browser RTP must reach FreeSWITCH from the Windows host. The container's
         internal IP ($${local_ip_v4}) is NOT routable from the host browser, so
         advertise the host LAN IP; the dev compose publishes 16384-16403/udp +
         5090, so media sent to 192.168.1.48:<rtp> forwards into the container.
         >>> Update 192.168.1.48 if your host LAN IP changes (run `ipconfig`). <<< -->
    <param name="ext-rtp-ip" value="192.168.1.48"/>
    <!-- SIP only ever talks to drachtio INSIDE the docker network, so keep the
         internal container IP. A host/public IP here makes drachtio send the
         endpoint INVITE to 192.168.1.48:5090, which hairpins through the published
         port and FS returns 404 Not Found (verified 2026-06-24). -->
    <param name="ext-sip-ip" value="$${local_ip_v4}"/>
    <param name="auth-calls" value="false"/>
    <param name="enable-timer" value="false"/>
    <param name="user-agent-string" value="Jambonz media gateway"/>
    <param name="username" value="Jambonz-Mediaserver"/>
    <param name="apply-nat-acl" value="nat.auto"/>
    <param name="context" value="mrf"/>
    <param name="rtp-timer-name" value="soft"/>
    <param name="codec-prefs" value="$${global_codec_prefs}"/>
    <param name="inbound-codec-negotiation" value="greedy"/>
    <param name="inbound-reg-force-matching-username" value="false"/>
    <param name="nonce-ttl" value="86400"/>
    <param name="manage-presence" value="false"/>

    <!-- Accept DTLS-SRTP (WebRTC) offers relayed by drachtio-fsmrf so browser
         clients can reach the IVR; fall back to plain RTP for softphones.
         Without this, FreeSWITCH answers WebRTC INVITEs with 488. -->
    <param name="rtp-secure-media" value="optional"/>

    <!-- Accept the browser's ICE candidates. WebRTC clients on a LAN/host send
         RFC1918 (192.168.x / 172.x / 10.x) and host candidates. The default
         ACL is wan.auto (public IPs only), so all candidates get filtered out
         => "no suitable candidates found" => 488. These ACLs (incl. the
         any_v4.auto catch-all) let FreeSWITCH use the offered candidates. -->
    <param name="apply-candidate-acl" value="localnet.auto"/>
    <param name="apply-candidate-acl" value="wan_v4.auto"/>
    <param name="apply-candidate-acl" value="rfc1918.auto"/>
    <param name="apply-candidate-acl" value="any_v4.auto"/>

    <!-- so we can send INVITEs with no SDP and get an offer back with all available codecs -->
    <param name="enable-3pcc" value="true"/>

    <param name="tls" value="false"/>
  </settings>
</profile>
