<include>
  <context name="mrf">

    <!-- drachtio-fsmrf: establish outbound event socket connection to the
         address specified in the X-esl-outbound header -->
    <extension name="socket">
      <condition field="${sip_user_agent}" expression="^drachtio-fsmrf:(.*)$">
        <!-- DIAGNOSTIC: confirm this extension matched and show the exact
             ESL-outbound callback FreeSWITCH will dial back to. ERR level so it
             surfaces in `docker logs drachtio-freeswitch`. -->
        <action application="log" data="ERR HIT SOCKET DIALPLAN ua=${sip_user_agent} esl=${sip_h_X-esl-outbound}"/>
        <!-- Browser legs arrive as WebRTC offers (UDP/TLS/RTP/SAVPF) relayed
             by drachtio. rtp_secure_media_inbound=true pins the inbound browser
             leg to DTLS-SRTP so FreeSWITCH answers the secure media offer
             instead of rejecting it with 488 Not Acceptable.
             rtp_secure_media (the general/trunk-facing policy) is driven by the
             mrf_secure_media global var (see vars.xml) so operators can relax
             SRTP on the outbound trunk/Teams leg without touching the browser
             leg. Default true = behaviour-preserving. -->
        <action application="set" data="rtp_secure_media=${mrf_secure_media}"/>
        <action application="set" data="rtp_secure_media_inbound=true"/>
        <action application="answer"/>
        <action application="set" data="send_silence_when_idle=-1"/>
        <action application="set" data="hangup_after_bridge=false"/>
        <action application="set" data="park_after_bridge=true"/>
        <action application="set" data="playback_terminators=none"/>
        <action application="socket" data="${sip_h_X-esl-outbound} async full"/>
      </condition>
    </extension>
  </context>
</include>
