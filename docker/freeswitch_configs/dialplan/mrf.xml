<include>
  <context name="mrf">

    <!-- drachtio-fsmrf: establish outbound event socket connection to the
         address specified in the X-esl-outbound header -->
    <extension name="socket">
      <condition field="${sip_user_agent}" expression="^drachtio-fsmrf:(.*)$">
        <!-- DIAGNOSTIC: confirm this extension matched and show the exact
             ESL-outbound callback FreeSWITCH will dial back to. ERR level so it
             surfaces in `docker logs drachtio-freeswitch`. -->
        <action application="log" data="ERR HIT SOCKET DIALPLAN ua=${sip_user_agent} esl=${sip_h_X-esl-outbound}"/>
        <!-- Browser legs arrive as WebRTC offers (UDP/TLS/RTP/SAVPF + a=fingerprint,
             NO a=crypto). Forcing rtp_secure_media_inbound=true requires an SDES
             a=crypto suite the DTLS offer never contains -> FreeSWITCH logs
             "Crypto not negotiated but required" and media dies ~3.5s after
             answer (the connectCaller "Connection timeout"). `optional` lets the
             DTLS offer auto-negotiate from a=fingerprint, and still accepts SDES
             if a peer (e.g. a SIP trunk leg) actually offers a=crypto. This
             mirrors the prod override (prod/freeswitch/dialplan-mrf.xml). -->
        <action application="set" data="rtp_secure_media=optional"/>
        <action application="set" data="rtp_secure_media_inbound=optional"/>
        <action application="answer"/>
        <action application="set" data="send_silence_when_idle=-1"/>
        <action application="set" data="hangup_after_bridge=false"/>
        <action application="set" data="park_after_bridge=true"/>
        <action application="set" data="playback_terminators=none"/>
        <action application="socket" data="172.17.0.1:8085 async full"/>
      </condition>
    </extension>
  </context>
</include>
