{
  "name": "callnet-api",
  "version": "1.0.0",
  "description": "WebRTC SIP Platform with Drachtio and FreeSWITCH",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "swc src -d dist --strip-leading-paths --ignore \"**/*.d.ts\"",
    "typecheck": "tsc --noEmit",
    "start": "bun dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@enjoys/exception": "^1.1.2",
    "@speechmatics/auth": "^0.1.0",
    "@speechmatics/real-time-client": "^8.4.0",
    "cors": "^2.8.6",
    "drachtio-fsmrf": "^4.1.1",
    "drachtio-srf": "^5.0.10",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  }
}