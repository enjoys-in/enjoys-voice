# CallNet Edge — agent environment (systemd EnvironmentFile).
# install.sh copies this to /etc/callnet-edge/agent.env on first run. EDIT the
# real file; do NOT commit secrets.

# Central management plane (the VPS) the agent syncs with.
CENTRAL_API_BASE=https://voice.enjoys.in

# Identity for THIS appliance (one per customer site). Prefer per-device mTLS in
# production; the bearer token is the bootstrap path.
DEVICE_ID=site-001
DEVICE_TOKEN=replace-with-device-token

# SIP domain phones register to (friendly name; FS also accepts its LAN IP).
SITE_DOMAIN=callnet.local

# FreeSWITCH ESL (loopback only) — the agent uses it for reloadxml / rescan.
FS_ESL_PASSWORD=JambonzR0ck$

# How often the agent reconciles config + flushes CDR/voicemail (seconds).
SYNC_INTERVAL_SECS=30

# coturn (used by install.sh to render /etc/turnserver.conf).
TURN_EXTERNAL_IP=192.168.1.50
TURN_USER=callnet
TURN_PASSWORD=replace-with-strong-secret
TURN_REALM=callnet.local
