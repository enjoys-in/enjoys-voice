# ─── CallNet Environment Configuration ───────────────────
# Copy this file to .env and fill in your values

# Server
HTTP_PORT=3001
WS_PORT=3002
PUBLIC_IP=127.0.0.1
DOMAIN=localhost
# SIP realm/URI domain (the @host in sip:<ext>@<domain> From/To). Optional —
# defaults to DOMAIN. Set to e.g. enjoys.in to present SIP identities on a
# dedicated SIP domain without changing the app/cookie DOMAIN.
SIP_DOMAIN=localhost

# ─── Drachtio SIP Server ─────────────────────────────────
DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=siprocks

# ─── FreeSWITCH Media Server ─────────────────────────────
FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_SECRET=ClueCon

# ─── RTPEngine ────────────────────────────────────────────
RTPENGINE_HOST=127.0.0.1
RTPENGINE_PORT=22222

# ─── IVR System ──────────────────────────────────────────
IVR_ENABLED=true
IVR_ENTRY=5000
IVR_DEFAULT_LANG=en
BIZ_HOURS_START=9
BIZ_HOURS_END=18
MAX_VOICEMAIL_SEC=180
RECORDINGS_DIR=/usr/local/freeswitch/recordings
# ffmpeg binary used by the Go API to normalize IVR sound uploads to the
# FreeSWITCH-canonical WAV (16k mono pcm_s16le). Resolved on PATH; provide an
# installed/sidecar ffmpeg. IVR uploads are rejected (503) when unavailable.
FFMPEG_PATH=ffmpeg
# Where normalized IVR prompts (.wav) are written. MUST be on a volume the
# FreeSWITCH container can read (IVR prompts are played server-side by FS).
IVR_SOUND_DIR=./uploads/ivr

# ─── SIP Trunk Provider ──────────────────────────────────
# Choose your active provider: telnyx, voipms, twilio, vonage, bandwidth, plivo, flowroute, bulkvs
SIP_TRUNK_PROVIDER=telnyx

# ─── Twilio SIP Trunk ────────────────────────────────────
# TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN are also used by the Go API for
# provider-native outbound caller-ID (BYON) verification. Leave them blank to
# disable that feature (the caller-id endpoints then return 503).
# TWILIO_SMS_FROM is used by the Go API to deliver OTP texts (mobile-verified
# signup + passwordless login): a Twilio phone number (+1...) or a Messaging
# Service SID (MG...). Blank disables OTP SMS (those endpoints return 503).
# CALLER_ID_VERIFY_TTL_DAYS: how many days a verified outbound caller ID stays
# valid before the user must re-verify (no provider re-check — purely time-based).
# The Go status API and the Node SQL gate both read this, so keep them equal.
# 0 disables expiry (a verified number never goes stale). Default 90.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
CALLER_ID_VERIFY_TTL_DAYS=90
TWILIO_SIP_DOMAIN=yourapp.pstn.twilio.com
TWILIO_SIP_USERNAME=
TWILIO_SIP_PASSWORD=
TWILIO_CALLER_NUMBER=+15551234567
TWILIO_TRUNK_SIP_URI=yourtrunk.pstn.twilio.com

# OTP_DEV_ECHO (Go API): when true, OTP codes are logged to the server console
# instead of requiring a live SMS gateway — handy for local dev. The code is
# NEVER returned in the HTTP response. Leave false in production.
OTP_DEV_ECHO=false

# ─── Telnyx (Best Free Tier - $1 credit) ─────────────────
# Sign up: https://portal.telnyx.com
# Pricing: $0.004/min inbound, $0.007/min outbound
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=
TELNYX_CALLER_NUMBER=
# TELNYX_CONNECTION_ID=

# ─── VoIP.ms (Cheapest DIDs - $0.85/month) ───────────────
# Sign up: https://voip.ms
# Pricing: $0.005/min US calls
VOIPMS_USERNAME=
VOIPMS_PASSWORD=
VOIPMS_CALLER_NUMBER=
# VOIPMS_SIP_HOST=atlanta1.voip.ms

# ─── Vonage/Nexmo ($2 free credit) ───────────────────────
# Sign up: https://dashboard.nexmo.com
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_CALLER_NUMBER=

# ─── Bandwidth (Free trial) ──────────────────────────────
# Sign up: https://www.bandwidth.com
# Pricing: $0.005/min + $0.35/month DID
BANDWIDTH_USERNAME=
BANDWIDTH_PASSWORD=
BANDWIDTH_CALLER_NUMBER=

# ─── Plivo (Best for India numbers) ──────────────────────
# Sign up: https://console.plivo.com
# Pricing: $0.003/min inbound (cheapest), India DIDs available
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_CALLER_NUMBER=

# ─── Flowroute ───────────────────────────────────────────
# Sign up: https://manage.flowroute.com
FLOWROUTE_ACCESS_KEY=
FLOWROUTE_SECRET_KEY=
FLOWROUTE_CALLER_NUMBER=

# ─── BulkVS (Cheapest Overall - $0.25/month DID) ─────────
# Sign up: https://portal.bulkvs.com
BULKVS_USERNAME=
BULKVS_PASSWORD=
BULKVS_CALLER_NUMBER=

# ─── Microsoft Teams dial-in (Audio Conferencing) ────────
# Lets users join a Teams meeting by dialing its Audio-Conferencing number
# over the trunk and auto-entering the Conference ID via DTMF.
# TEAMS_DTMF_DELAY_MS: how long to wait after the dial-in answers before
#   sending the Conference ID digits (the IVR needs a moment to pick up).
# TEAMS_DEFAULT_DIALIN: optional fallback dial-in number used when a join
#   request doesn't carry its own (e.g. a fixed regional bridge number).
# TEAMS_JOIN_FAIL_MS: if the Teams/trunk leg drops within this window after the
#   caller is bridged in, the Conference ID was most likely wrong/expired, so we
#   play a spoken "couldn't join, check the conference ID" prompt instead of a
#   silent drop.
TEAMS_DTMF_DELAY_MS=4000
TEAMS_DEFAULT_DIALIN=
TEAMS_JOIN_FAIL_MS=8000

# ─── Prepaid billing (wallet + pre-call balance gate) ────
# Opt-in prepaid wallets. When enabled, an outbound (PSTN) call is refused if
# the caller's wallet can't cover the cheapest possible charge (setup fee + one
# billing increment) for the destination, and the wallet is debited by the
# rated cost at end-of-call. When disabled, there is no gate and no debit —
# call rating still runs for reporting. BOTH the Go API and the Node engine read
# these, so they MUST be set identically in both environments.
# BILLING_CURRENCY: single ISO-4217 currency for all wallets (e.g. USD, INR).
BILLING_PREPAID_ENABLED=false
BILLING_CURRENCY=USD
# BILLING_BLOCK_UNRATED (Node call path): anti-toll-fraud. When true AND a rate
# book is loaded, an outbound call to a destination with NO configured rate is
# refused (SIP 403) instead of routing free. Skipped when no rates are set up,
# so a workspace without a rate book still places calls normally. Leave false
# until your rate plans cover every destination you intend to allow.
BILLING_BLOCK_UNRATED=false

# ADMIN_EXTENSIONS (Go API): comma-separated extensions allowed to perform admin
# billing actions — crediting wallets (top-ups) and reading another user's
# wallet/ledger. There is no role column in this schema, so admin identity is
# this allow-list. Empty = no admins (every admin-only billing endpoint is
# denied), which is the safe default — set it before using top-ups.
ADMIN_EXTENSIONS=

